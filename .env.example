POSTGRES_DB=contactcore
POSTGRES_USER=contactcore
POSTGRES_PASSWORD=contactcore

# Optional. Set to demo to load repeatable sample data from db/demo.
SPRING_PROFILES_ACTIVE=

CONTACTCORE_API_PORT=8080
CONTACTCORE_WEB_PORT=5173
CONTACTCORE_ADMIN_USERNAME=admin
CONTACTCORE_ADMIN_EMAIL=admin@contactcore.local
CONTACTCORE_ADMIN_PASSWORD=change-this-password
CONTACTCORE_ADMIN_DISPLAY_NAME=ContactCore Admin
CONTACTCORE_JWT_ISSUER=contactcore-crm
CONTACTCORE_JWT_SECRET=replace-this-with-a-long-random-secret-value-32-bytes-minimum
CONTACTCORE_JWT_TTL_MINUTES=480
CONTACTCORE_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

CONTACTCORE_S3_ENDPOINT=http://minio:9000
CONTACTCORE_S3_PUBLIC_ENDPOINT=http://localhost:9000
CONTACTCORE_S3_REGION=eu-central-1
CONTACTCORE_S3_BUCKET=contactcore-files
CONTACTCORE_S3_ACCESS_KEY=contactcore
CONTACTCORE_S3_SECRET_KEY=contactcore-secret
CONTACTCORE_S3_PATH_STYLE_ACCESS=true

CONTACTCORE_FILE_SCANNING_ENABLED=true
CONTACTCORE_FILE_SCANNING_HOST=clamav
CONTACTCORE_FILE_SCANNING_PORT=3310
CONTACTCORE_FILE_SCANNING_HOST_PORT=3310
CONTACTCORE_FILE_SCANNING_CONNECT_TIMEOUT_MS=3000
CONTACTCORE_FILE_SCANNING_READ_TIMEOUT_MS=30000
CONTACTCORE_FILE_SCANNING_CHUNK_SIZE_BYTES=8192

CONTACTCORE_UPLOAD_MAX_PROFILE_IMAGE_BYTES=5242880
CONTACTCORE_UPLOAD_MAX_BUSINESS_DOCUMENT_BYTES=15728640

CONTACTCORE_ASSISTANT_ENABLED=true
CONTACTCORE_ASSISTANT_PROVIDER=noop
CONTACTCORE_ASSISTANT_MODEL=contactcore-noop
CONTACTCORE_ASSISTANT_ENDPOINT=
CONTACTCORE_ASSISTANT_API_KEY=
CONTACTCORE_ASSISTANT_TIMEOUT_MS=20000
CONTACTCORE_ASSISTANT_MAX_CONTEXT_CHARS=12000
CONTACTCORE_ASSISTANT_MAX_RESULTS=20
CONTACTCORE_ASSISTANT_RATE_LIMIT_PER_MINUTE=10
